---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const slug = Astro.params.slug;

// Read file directly instead of using getCollection (which only works at build time)
const blogDir = path.join(process.cwd(), 'src/content/blog');
const files = fs.readdirSync(blogDir).filter(f => f.endsWith('.md'));

// Find the file that matches the slug (filename without .md)
const file = files.find(f => f.replace('.md', '') === slug);

if (!file) {
  return Astro.redirect('/404');
}

// Read and parse the file
const filePath = path.join(blogDir, file);
const content = fs.readFileSync(filePath, 'utf-8');

const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);
let title = slug;
let date = new Date();
let time: string | undefined;
let tags: string[] = [];
let body = content;

if (frontmatterMatch) {
  const fm = frontmatterMatch[1];
  const titleMatch = fm.match(/title:\s*["']?([^"'\n]+)["']?/);
  const dateMatch = fm.match(/date:\s*(\S+)/);
  const timeMatch = fm.match(/time:\s*(\S+)/);
  const tagsMatch = fm.match(/tags:\s*\[([^\]]+)\]/);
  
  if (titleMatch) title = titleMatch[1].replace(/["']/g, '');
  if (dateMatch) date = new Date(dateMatch[1]);
  if (timeMatch) time = timeMatch[1];
  if (tagsMatch) {
    tags = tagsMatch[1].split(',').map((t: string) => t.trim().replace(/["']/g, ''));
  }
  
  // Get body content (after frontmatter)
  body = content.slice(frontmatterMatch[0].length).trim();
}

// Simple markdown to HTML conversion for the body
const contentHtml = body
  .replace(/^### (.*$)/gm, '<h3>$1</h3>')
  .replace(/^## (.*$)/gm, '<h2>$1</h2>')
  .replace(/^# (.*$)/gm, '<h1>$1</h1>')
  .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
  .replace(/\*(.*?)\*/g, '<em>$1</em>')
  .replace(/\n/g, '<br>');

function formatTimestamp(date: Date | string, time?: string): string {
  const dateObj = date instanceof Date ? date : new Date(date);
  const dateStr = dateObj.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
  
  if (time) {
    const [hours, minutes] = time.split(':');
    const dateWithTime = new Date(dateObj);
    dateWithTime.setHours(parseInt(hours, 10), parseInt(minutes, 10));
    const timeStr = dateWithTime.toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true
    });
    return `${dateStr} at ${timeStr}`;
  }
  
  return dateStr;
}

const formattedDate = formatTimestamp(date, time);
---

<Layout title={`${title} | Markdown Blog`}>
  <a href="/" class="back-link">← Back to Home</a>
  <article class="article-card">
    <h1>{title}</h1>
    <p class="entry-date"><em>{formattedDate}</em></p>
    <div set:html={contentHtml} />
  </article>
</Layout>
