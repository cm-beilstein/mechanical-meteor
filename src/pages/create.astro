---
import Layout from '../layouts/Layout.astro';
import PostForm from '../components/PostForm.astro';
import MarkdownPreview from '../components/MarkdownPreview.astro';
---

<Layout title="Create New Post | Markdown Blog">
  <div class="create-page">
    <header class="page-header">
      <h1>Create New Post</h1>
      <a href="/" class="back-link">← Back to Home</a>
    </header>

    <div class="create-layout">
      <div class="form-section">
        <PostForm />
      </div>
      <div class="preview-section">
        <MarkdownPreview content="" />
      </div>
    </div>
  </div>
</Layout>

<script>
  // Connect form to preview - update preview as user types
  const contentTextarea = document.getElementById('content') as HTMLTextAreaElement;
  const previewContainer = document.querySelector('.preview-content');

  if (contentTextarea && previewContainer) {
    contentTextarea.addEventListener('input', () => {
      const markdown = contentTextarea.value;
      // Simple markdown to HTML conversion
      const html = parseMarkdown(markdown);
      previewContainer.innerHTML = html;
    });
  }

  function parseMarkdown(text: string): string {
    if (!text.trim()) {
      return '<p class="placeholder">Start typing to see preview...</p>';
    }

    let html = text
      // Escape HTML first
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      // Code blocks (must be before inline code)
      .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
      // Inline code
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      // Headers
      .replace(/^###### (.+)$/gm, '<h6>$1</h6>')
      .replace(/^##### (.+)$/gm, '<h5>$1</h5>')
      .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      .replace(/^# (.+)$/gm, '<h1>$1</h1>')
      // Bold and italic
      .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      // Links
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
      // Images
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />')
      // Blockquotes
      .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
      // Horizontal rule
      .replace(/^---$/gm, '<hr />')
      // Line breaks - convert double newlines to paragraphs
      .replace(/\n\n/g, '</p><p>')
      // Single newlines to <br>
      .replace(/\n/g, '<br />');

    // Wrap in paragraph tags
    html = '<p>' + html + '</p>';

    // Clean up empty paragraphs
    html = html.replace(/<p><\/p>/g, '');
    html = html.replace(/<p>(<h[1-6]>)/g, '$1');
    html = html.replace(/(<\/h[1-6]>)<\/p>/g, '$1');
    html = html.replace(/<p>(<pre>)/g, '$1');
    html = html.replace(/(<\/pre>)<\/p>/g, '$1');
    html = html.replace(/<p>(<blockquote>)/g, '$1');
    html = html.replace(/(<\/blockquote>)<\/p>/g, '$1');
    html = html.replace(/<p>(<hr \/>)<\/p>/g, '$1');

    // Merge consecutive blockquotes
    html = html.replace(/<\/blockquote><br \/><blockquote>/g, '<br />');

    return html;
  }
</script>

<style>
  .create-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: 1.75rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-primary, #0070f3);
  }

  .create-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    min-height: 600px;
  }

  .form-section {
    display: flex;
    flex-direction: column;
  }

  .preview-section {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 900px) {
    .create-layout {
      grid-template-columns: 1fr;
    }

    .preview-section {
      order: -1;
    }
  }

  .placeholder {
    color: var(--color-text-muted, #666666);
    font-style: italic;
  }
</style>