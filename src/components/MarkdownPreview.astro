---
interface Props {
  content: string;
}

const { content } = Astro.props;
---

<div class="markdown-preview">
  <h3 class="preview-header">Preview</h3>
  <div class="preview-content article-card" set:html={content} />
</div>

<style>
  .markdown-preview {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .preview-header {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted, #666666);
    font-weight: 500;
  }

  .preview-content {
    flex: 1;
    overflow-y: auto;
    min-height: 400px;
  }

  /* Style content that comes from markdown */
  .preview-content :global(h1),
  .preview-content :global(h2),
  .preview-content :global(h3) {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .preview-content :global(p) {
    margin: 0.5rem 0;
  }

  .preview-content :global(ul),
  .preview-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }

  .preview-content :global(code) {
    background: #f0f0f0;
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .preview-content :global(pre) {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 0.75rem 0;
  }

  .preview-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .preview-content :global(blockquote) {
    border-left: 4px solid var(--color-primary, #0070f3);
    margin: 0.75rem 0;
    padding-left: 1rem;
    color: var(--color-text-muted, #666666);
  }

  .preview-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .preview-content :global(hr) {
    border: none;
    border-top: 1px solid #e5e5e5;
    margin: 1rem 0;
  }
</style>